# ============================================================
# REQUIRED FOR VERCEL (all free, no credit card)
# ============================================================

# 1. ScraperAPI — enables Craigslist
#    Sign up: scraperapi.com → key shown on dashboard immediately
#    Free tier: 5,000 requests/month
SCRAPER_API_KEY=

# 2. Google Custom Search — enables web-wide lead discovery
#    Free tier: 100 searches/day (~3,000/month), no credit card
#
#    Get API key (2 min):
#      console.cloud.google.com → Create project → Search "Custom Search API"
#      → Enable → Credentials → Create API Key → copy it
#
#    Get Search Engine ID (2 min):
#      programmablesearchengine.google.com → Add → name anything
#      → Sites to search: craigslist.org → Create
#      → Edit → Setup → turn ON "Search the entire web" → copy the cx ID
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# ============================================================
# OPTIONAL TUNING
# ============================================================
FETCH_TIMEOUT_MS=12000
MAX_RESULTS_PER_SOURCE=20

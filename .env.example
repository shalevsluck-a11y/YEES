# ============================================================
# REQUIRED FOR VERCEL (all free, no credit card)
# ============================================================

# 1. ScraperAPI — enables Craigslist
#    Sign up: scraperapi.com → key shown on dashboard immediately
#    Free tier: 5,000 requests/month
SCRAPER_API_KEY=

# 2. Serper.dev — enables Google Search (finds Craigslist + Reddit posts)
#    Free tier: 2,500 searches, no credit card
#    Sign up: serper.dev → copy API key from dashboard
SERPER_API_KEY=

# ============================================================
# OPTIONAL TUNING
# ============================================================
FETCH_TIMEOUT_MS=12000
MAX_RESULTS_PER_SOURCE=20

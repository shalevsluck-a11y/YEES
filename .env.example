# Optional: Bing Search API key for fallback discovery
# Get one free at https://www.microsoft.com/en-us/bing/apis/bing-web-search-api
# Without this key, the fallback adapter uses HTML scraping instead (less reliable)
BING_API_KEY=

# Optional: Request timeout in milliseconds (default: 12000)
FETCH_TIMEOUT_MS=12000

# Optional: Max results per source per query (default: 20)
MAX_RESULTS_PER_SOURCE=20

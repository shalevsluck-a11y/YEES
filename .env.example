# ============================================================
# REQUIRED FOR VERCEL DEPLOYMENT (all free, no credit card)
# ============================================================

# 1. ScraperAPI — enables Craigslist (Craigslist blocks Vercel IPs without this)
#    Sign up free at scraperapi.com → key shown on dashboard immediately
#    Free tier: 5,000 requests/month
SCRAPER_API_KEY=

# 2. Brave Search API — enables web-wide lead discovery (Craigslist + Reddit via search index)
#    Sign up free at api.search.brave.com → Free plan → copy API key
#    Free tier: 2,000 queries/month, no credit card required
BRAVE_SEARCH_API_KEY=

# ============================================================
# OPTIONAL (if you already have a Bing key from Azure)
# ============================================================
BING_API_KEY=

# ============================================================
# OPTIONAL TUNING
# ============================================================
FETCH_TIMEOUT_MS=12000
MAX_RESULTS_PER_SOURCE=20

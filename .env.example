# ============================================================
# REQUIRED FOR VERCEL DEPLOYMENT (all free)
# ============================================================

# 1. ScraperAPI — enables Craigslist (Craigslist blocks Vercel IPs without this)
#    Get free key (5,000 req/month): https://www.scraperapi.com
SCRAPER_API_KEY=

# 2. Reddit OAuth — enables Reddit forum search reliably from Vercel
#    Get free: go to reddit.com/prefs/apps → create app → script type
#    client_id is shown under your app name (short string)
#    client_secret is labeled "secret"
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# 3. Bing Search API — enables fallback discovery
#    Get free (1,000 searches/month): https://www.microsoft.com/en-us/bing/apis/bing-web-search-api
BING_API_KEY=

# ============================================================
# OPTIONAL TUNING
# ============================================================
FETCH_TIMEOUT_MS=12000
MAX_RESULTS_PER_SOURCE=20
